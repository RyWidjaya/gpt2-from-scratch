  {
   "cell_type": "code",
   "execution_count": null,
   "id": "15479481",
   "metadata": {},
   "outputs": [],
   "source": [
    "# load backed up shards\n",
    "# NOTE: the size check must compare against the SOURCE file, not just existence --\n",
    "# an interrupted earlier run can leave a half-copied local file behind, and a\n",
    "# truncated shard on Drive would otherwise be silently accepted as \"done\"\n",
    "import shutil, os\n",
    "os.makedirs(\"edu_fineweb10B\", exist_ok=True)\n",
    "src_dir = \"/content/drive/MyDrive/edu_fineweb10B\"\n",
    "files = os.listdir(src_dir)\n",
    "for i, f in enumerate(files):\n",
    "    src = os.path.join(src_dir, f)\n",
    "    dst = os.path.join(\"edu_fineweb10B\", f)\n",
    "    if not os.path.exists(dst) or os.path.getsize(dst) != os.path.getsize(src):\n",
    "        shutil.copy(src, dst)\n",
    "    print(f\"copied {i+1}/{len(files)}: {f}\")\n",
    "print(\"total files now:\", len(os.listdir(\"edu_fineweb10B\")))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "b36b00bc",
   "metadata": {},
   "outputs": [],
   "source": [
    "# =============================================================================\n",
    "# SHARD VERIFY & REPAIR\n",
    "# =============================================================================\n",
    "# The size check found the problem: edufineweb_val_000000.npy is 125,829,120\n",
    "# bytes -- exactly 120 MiB -- on BOTH Drive and local disk, but a complete\n",
    "# shard (100M uint16 tokens + a 128-byte npy header, per fineweb.py) is\n",
    "# 200,000,128 bytes. A perfect MiB multiple is the signature of an interrupted\n",
    "# upload: Drive received a clean prefix of the file and nothing after it. The\n",
    "# local copy matches because the copy cell faithfully copied the already-\n",
    "# truncated Drive file.\n",
    "#\n",
    "# Why this breaks training: the npy header still promises 100,000,000 tokens,\n",
    "# so np.load() inside load_tokens() hits end-of-file and raises the moment the\n",
    "# val loader opens the shard -- the training cell dies at step 0.\n",
    "#\n",
    "# The repair: the bytes that DID arrive are a valid prefix of the token\n",
    "# stream, so we keep every complete token present (~62.9M) and rewrite the\n",
    "# file as a self-consistent .npy. That is vastly more than the val loop ever\n",
    "# reads (20 batches x 8 x 1024 = 163,840 tokens), and the DataLoader wraps\n",
    "# around shards anyway, so a shorter shard is harmless. The repaired file is\n",
    "# copied back to Drive so future sessions don't re-download the broken one.\n",
    "# (A pristine shard would mean re-running fineweb.py and re-uploading -- hours\n",
    "# of tokenization for a val split we barely sample. Not worth it.)\n",
    "\n",
    "import os, shutil\n",
    "import numpy as np\n",
    "\n",
    "def npy_data_offset(path):\n",
    "    # parse the real header instead of assuming 128 bytes\n",
    "    with open(path, 'rb') as f:\n",
    "        version = np.lib.format.read_magic(f)\n",
    "        if version == (1, 0):\n",
    "            np.lib.format.read_array_header_1_0(f)\n",
    "        else:\n",
    "            np.lib.format.read_array_header_2_0(f)\n",
    "        return f.tell()\n",
    "\n",
    "def check_and_repair(path):\n",
    "    size = os.path.getsize(path)\n",
    "    try:\n",
    "        # mmap validates header length against file size without reading 200MB\n",
    "        np.load(path, mmap_mode='r')\n",
    "        print(f\"OK        {os.path.basename(path)} ({size:,} bytes)\")\n",
    "        return False\n",
    "    except Exception:\n",
    "        pass\n",
    "    offset = npy_data_offset(path)\n",
    "    n_tokens = (size - offset) // 2  # complete tokens actually present\n",
    "    print(f\"TRUNCATED {os.path.basename(path)} ({size:,} bytes) -> rewriting as {n_tokens:,} tokens\")\n",
    "    tokens = np.fromfile(path, dtype=np.uint16, offset=offset, count=n_tokens)\n",
    "    tmp = path + \".tmp.npy\"\n",
    "    np.save(tmp, tokens)\n",
    "    os.replace(tmp, path)\n",
    "    np.load(path, mmap_mode='r')  # must load cleanly now\n",
    "    return True\n",
    "\n",
    "local_dir = \"edu_fineweb10B\"\n",
    "drive_dir = \"/content/drive/MyDrive/edu_fineweb10B\"\n",
    "\n",
    "for name in sorted(os.listdir(local_dir)):\n",
    "    if not name.endswith(\".npy\"):\n",
    "        continue\n",

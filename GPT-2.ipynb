  {
   "cell_type": "code",
   "execution_count": null,
   "id": "761c1448",
   "metadata": {},
   "outputs": [],
   "source": [
    "# =============================================================================\n",
    "# EXTENSION RUN -- continue the finished 2,609-step model to 3,000 steps\n",
    "# =============================================================================\n",
    "# A copy of the training cell above with ONLY the changes an extension needs:\n",
    "#\n",
    "# 1) max_steps = 3000, hardcoded. Resume loads latest.pt from the finished run,\n",
    "#    so the loop runs just the remaining ~390 steps: ~390 x ~14s = ~1.5-2h in a\n",
    "#    single session (plus a few minutes of torch.compile on the first step).\n",
    "#\n",
    "# 2) LEARNING RATE -- no edit needed, but know why: the original cosine had\n",
    "#    already decayed to min_lr by step 2609. Raising max_steps re-stretches the\n",
    "#    cosine, so the resumed steps train at a gently decaying ~8.4e-5 -> 6e-5\n",
    "#    instead of a hard floor. Correct behaviour for a short extension.\n",
    "#\n",
    "# 3) SAFETY GUARD: if no checkpoint is found (wrong Google account mounted,\n",
    "#    failed mount), this cell RAISES instead of silently starting from scratch.\n",
    "#    A scratch run would overwrite latest.pt at its first checkpoint and\n",
    "#    destroy the finished model's training state.\n",
    "#\n",
    "# 4) FINAL EXPORT goes to gpt2_124M_step3000.pt -- a separate file, so the\n",
    "#    original gpt2_124M_final.pt on Drive is untouched and both models can be\n",
    "#    compared side by side.\n",
    "#\n",
    "# Run order in a fresh session: architecture cells -> mount -> copy shards ->\n",
    "# repair -> THIS cell (skip the original training cell above).\n",
    "#\n",
    "# Expectation check: +390 steps is +15% more tokens (~393M total seen). Val\n",
    "# loss should tick down slightly (~0.03-0.05). This squeezes a bit more out of\n",
    "# the model -- it will not fix the rambling, which is a scale/base-model trait.\n",
    "# =============================================================================\n",
    "\n",
    "import os\n",
    "import time\n",
    "import math\n",
    "import shutil\n",
    "import numpy as np\n",
    "import tiktoken\n",
    "import torch\n",
    "import torch.nn.functional as F\n",
    "\n",
    "drive_checkpoint_dir = \"/content/drive/MyDrive/gpt2_t4_run\"  # fresh dir -- don't mix with the old demo run's incompatible checkpoints\n",
    "os.makedirs(drive_checkpoint_dir, exist_ok=True)\n",
    "\n",
    "torch.manual_seed(1337)\n",
    "master_process = True\n",
    "\n",
    "device = 'cuda' if torch.cuda.is_available() else 'cpu'\n",
    "print(f\"using device: {device}\")\n",
    "if torch.cuda.is_available():\n",
    "    torch.cuda.manual_seed(1337)\n",
    "\n",
    "enc = tiktoken.get_encoding(\"gpt2\")\n",
    "\n",
    "# -----------------------------------------------------------------------------\n",
    "# budget knobs -- everything about the 10h plan is derived from these\n",
    "# -----------------------------------------------------------------------------\n",
    "B = 8      # T4 CHANGE: micro batch size doubled from 4 -- fits in 16GB with fp16 activations\n",
    "T = 1024   # sequence length (block_size)\n",
    "total_batch_size = 131072  # 2**17 tokens per optimizer step -- see point (4) above\n",
    "assert total_batch_size % (B * T) == 0\n",
    "grad_accum_steps = total_batch_size // (B * T)  # = 16 micro-batches per step\n",
    "\n",
    "ASSUMED_TOK_PER_SEC = 9500   # conservative T4 estimate -- recalibrate from real tok/sec after ~20 steps\n",
    "TARGET_TRAIN_HOURS = 10.0\n",
    "max_steps = 3000  # EXTENSION: hardcoded target (original run derived ~2609 from the 10h budget)\n",
    "warmup_steps = 100           # ~13M tokens of warmup -- short runs need far less than the 715 used for 10B-token runs\n",
    "\n",
    "max_lr = 6e-4\n",
    "min_lr = max_lr * 0.1\n",
    "\n",
    "SESSION_TIME_LIMIT_HOURS = 10.5  # per-SESSION safety stop: checkpoint + exit cleanly before Colab kills us\n",
    "CHECKPOINT_EVERY = 100           # ~45 min apart at expected speed -- max progress lost to a disconnect\n",
    "VAL_EVERY = 100\n",
    "SAMPLE_EVERY = 500\n",
    "\n",
    "if master_process:\n",
    "    print(f\"plan: {max_steps} steps x {total_batch_size:,} tokens = {max_steps * total_batch_size / 1e6:.0f}M tokens\")\n",
    "    print(f\"      grad_accum_steps={grad_accum_steps} (B={B}, T={T}), warmup={warmup_steps}\")\n",
    "    print(f\"      (resuming -- only the steps remaining after the loaded checkpoint will run)\")\n",
    "\n",
    "# -----------------------------------------------------------------------------\n",
    "# data loading -- same as before, plus get_state/set_state so a resumed run\n",
    "# continues from the same place in the data stream instead of re-reading shard 0\n",
    "# -----------------------------------------------------------------------------\n",
    "def load_tokens(filename):\n",
    "    npt = np.load(filename)\n",
    "    ptt = torch.tensor(npt, dtype=torch.long)\n",
    "    return ptt\n",
    "\n",
    "class DataLoaderLite:\n",
    "    def __init__(self, B, T, split):\n",
    "        self.B = B\n",
    "        self.T = T\n",
    "        assert split in {'train', 'val'}\n",
    "        data_root = \"edu_fineweb10B\"\n",
    "        shards = os.listdir(data_root)\n",
    "        shards = [s for s in shards if split in s]\n",
    "        shards = sorted(shards)\n",
    "        shards = [os.path.join(data_root, s) for s in shards]\n",
    "        self.shards = shards\n",
    "        assert len(shards) > 0, f\"no shards found for split {split}\"\n",
    "        if master_process:\n",
    "            print(f\"found {len(shards)} shards for split {split}\")\n",
    "        self.reset()\n",
    "\n",
    "    def reset(self):\n",
    "        self.current_shard = 0\n",
    "        self.tokens = load_tokens(self.shards[self.current_shard])\n",
    "        self.current_position = 0\n",
    "\n",
    "    # RESUME ADDED: expose/restore the loader's exact position for checkpointing\n",
    "    def get_state(self):\n",
    "        return {'current_shard': self.current_shard, 'current_position': self.current_position}\n",
    "\n",
    "    def set_state(self, state):\n",
    "        self.current_shard = state['current_shard'] % len(self.shards)  # modulo in case fewer shards exist on this machine\n",
    "        self.tokens = load_tokens(self.shards[self.current_shard])\n",
    "        self.current_position = state['current_position']\n",
    "\n",
    "    def next_batch(self):\n",
    "        B, T = self.B, self.T\n",
    "        buf = self.tokens[self.current_position : self.current_position + B * T + 1]\n",
    "        x = buf[:-1].view(B, T)  # inputs\n",
    "        y = buf[1:].view(B, T)   # labels = inputs shifted by 1\n",
    "        self.current_position += B * T\n",
    "        if self.current_position + (B * T + 1) > len(self.tokens):\n",
    "            self.current_shard = (self.current_shard + 1) % len(self.shards)\n",
    "            self.tokens = load_tokens(self.shards[self.current_shard])\n",
    "            self.current_position = 0\n",
    "        return x, y\n",
    "\n",
    "train_loader = DataLoaderLite(B=B, T=T, split='train')\n",
    "val_loader = DataLoaderLite(B=B, T=T, split='val')\n",
    "\n",
    "# harmless no-op on the T4 (TF32 is Ampere+) but keeps the cell portable to better GPUs\n",
    "torch.set_float32_matmul_precision('high')\n",
    "\n",
    "# -----------------------------------------------------------------------------\n",
    "# model -- raw_model stays uncompiled for checkpointing (clean state_dict keys,\n",
    "# no '_orig_mod.' prefix) and for generation (no recompiles on growing sequences)\n",
    "# -----------------------------------------------------------------------------\n",
    "model = GPT(GPTConfig(vocab_size=50304))\n",
    "model.to(device)\n",
    "raw_model = model\n",
    "use_compile = True  # T4 CHANGE: enabled -- fine here because we skip HellaSwag and generate via raw_model\n",
    "if use_compile and device == 'cuda':\n",
    "    model = torch.compile(model)\n",
    "\n",
    "# LR schedule: warmup + cosine decay, identical shape to before, just resized\n",
    "def get_lr(it):\n",
    "    if it < warmup_steps:\n",
    "        return max_lr * (it + 1) / warmup_steps\n",
    "    if it > max_steps:\n",
    "        return min_lr\n",
    "    decay_ratio = (it - warmup_steps) / (max_steps - warmup_steps)\n",
    "    assert 0 <= decay_ratio <= 1\n",
    "    coeff = 0.5 * (1.0 + math.cos(math.pi * decay_ratio))\n",
    "    return min_lr + coeff * (max_lr - min_lr)\n",
    "\n",
    "optimizer = raw_model.configure_optimizers(weight_decay=0.1, learning_rate=max_lr, device=device)\n",
    "\n",
    "# T4 CHANGE: GradScaler for fp16 training -- scales the loss up before backward()\n",
    "# so tiny fp16 gradients don't underflow to zero, then un-scales before stepping.\n",
    "# (bf16 doesn't need this, but bf16 has no tensor-core support on Turing.)\n",
    "scaler = torch.amp.GradScaler(device, enabled=(device == 'cuda'))\n",
    "\n",
    "log_dir = \"log\"\n",
    "os.makedirs(log_dir, exist_ok=True)\n",
    "# log file lives ON DRIVE so training history survives disconnects too\n",
    "log_file = os.path.join(drive_checkpoint_dir, \"log.txt\")\n",
    "\n",
    "last_val_loss = float('nan')  # updated at every val eval; stored inside checkpoints\n",
    "\n",
    "# RESUME ADDED: single rotating 'latest.pt' on Drive (~1.5GB with optimizer state --\n",
    "# overwriting one file instead of accumulating keeps free-tier Drive from filling up).\n",
    "# Written atomically: save locally -> copy to Drive as .tmp -> os.replace, so a\n",
    "# disconnect mid-write can never leave a corrupt half-checkpoint as 'latest'.\n",
    "def save_checkpoint(step):\n",
    "    checkpoint = {\n",
    "        'model': raw_model.state_dict(),\n",
    "        'optimizer': optimizer.state_dict(),\n",
    "        'scaler': scaler.state_dict(),\n",
    "        'train_loader': train_loader.get_state(),\n",
    "        'config': raw_model.config,\n",
    "        'step': step,\n",
    "        'val_loss': last_val_loss,\n",
    "    }\n",
    "    local_path = os.path.join(log_dir, \"latest.pt\")\n",
    "    torch.save(checkpoint, local_path)\n",
    "    try:\n",
    "        tmp_path = os.path.join(drive_checkpoint_dir, \"latest.pt.tmp\")\n",
    "        final_path = os.path.join(drive_checkpoint_dir, \"latest.pt\")\n",
    "        shutil.copy(local_path, tmp_path)\n",
    "        os.replace(tmp_path, final_path)\n",
    "        print(f\"step {step}: checkpoint saved to Drive\")\n",
    "    except Exception as e:\n",
    "        print(f\"WARNING: failed to copy checkpoint to Drive: {e}\")\n",
    "\n",
    "# RESUME ADDED: full-state resume -- model, optimizer (AdamW momentum/variance),\n",
    "# scaler, AND dataloader position, so continuing is near-exact rather than the\n",
    "# approximate weights-only resume used in the cell above.\n",
    "start_step = 0\n",
    "resume_path = os.path.join(drive_checkpoint_dir, \"latest.pt\")\n",
    "if os.path.exists(resume_path):\n",
    "    print(f\"found checkpoint {resume_path}, resuming...\")\n",
    "    # weights_only=False needed on torch>=2.6 because the checkpoint contains the GPTConfig dataclass\n",
    "    checkpoint = torch.load(resume_path, map_location=device, weights_only=False)\n",
    "    raw_model.load_state_dict(checkpoint['model'])\n",
    "    optimizer.load_state_dict(checkpoint['optimizer'])\n",
    "    scaler.load_state_dict(checkpoint['scaler'])\n",
    "    train_loader.set_state(checkpoint['train_loader'])\n",
    "    last_val_loss = checkpoint['val_loss']\n",
    "    start_step = checkpoint['step'] + 1\n",
    "    print(f\"resumed at step {start_step} (val loss was {last_val_loss:.4f})\")\n",
    "else:\n",
    "    # EXTENSION GUARD: this cell only continues an existing run. Starting from\n",
    "    # scratch would clobber latest.pt at its first checkpoint save -- check the\n",
    "    # Drive mount / Google account and rerun instead.\n",
    "    raise RuntimeError(f\"no checkpoint at {resume_path} -- refusing to start from scratch\")\n",
    "\n",
    "# generation always through raw_model (uncompiled) -- also your prompt interface\n",
    "# after training: generate(\"Once upon a time,\") on a loaded checkpoint\n",
    "def generate(prompt, max_new_tokens=48, num_samples=3, top_k=50, seed=42):\n",
    "    raw_model.eval()\n",
    "    tokens = enc.encode(prompt)\n",
    "    xgen = torch.tensor(tokens, dtype=torch.long).unsqueeze(0).repeat(num_samples, 1).to(device)\n",
    "    rng = torch.Generator(device=device)\n",
    "    rng.manual_seed(seed)\n",
    "    with torch.no_grad():\n",
    "        while xgen.size(1) < len(tokens) + max_new_tokens:\n",
    "            logits, _ = raw_model(xgen)\n",
    "            probs = F.softmax(logits[:, -1, :], dim=-1)\n",
    "            topk_probs, topk_indices = torch.topk(probs, top_k, dim=-1)\n",
    "            ix = torch.multinomial(topk_probs, 1, generator=rng)\n",
    "            xgen = torch.cat((xgen, torch.gather(topk_indices, -1, ix)), dim=1)\n",
    "    for i in range(num_samples):\n",
    "        print(f\"sample {i}: {enc.decode(xgen[i].tolist())}\")\n",
    "\n",
    "# -----------------------------------------------------------------------------\n",
    "# training loop\n",
    "# -----------------------------------------------------------------------------\n",
    "session_start = time.time()\n",
    "step = start_step  # keep defined even if the loop body never runs (already-finished run)\n",
    "for step in range(start_step, max_steps):\n",
    "    t0 = time.time()\n",
    "    last_step = (step == max_steps - 1)\n",
    "\n",
    "    # per-session wall-clock guard: checkpoint and stop cleanly before Colab's\n",
    "    # limit kills the runtime -- rerun this cell in a new session to continue\n",
    "    if (time.time() - session_start) > SESSION_TIME_LIMIT_HOURS * 3600:\n",
    "        print(f\"session time limit reached at step {step}, saving and stopping\")\n",
    "        save_checkpoint(step - 1)\n",
    "        break\n",
    "\n",
    "    # validation loss\n",
    "    if step % VAL_EVERY == 0 or last_step:\n",
    "        model.eval()\n",
    "        val_loader.reset()\n",
    "        with torch.no_grad():\n",
    "            val_loss_accum = 0.0\n",
    "            val_loss_steps = 20\n",
    "            for _ in range(val_loss_steps):\n",
    "                x, y = val_loader.next_batch()\n",
    "                x, y = x.to(device), y.to(device)\n",
    "                with torch.autocast(device_type=device, dtype=torch.float16):\n",
    "                    logits, loss = model(x, y)\n",
    "                val_loss_accum += (loss / val_loss_steps).detach()\n",
    "        last_val_loss = val_loss_accum.item()\n",
    "        if master_process:\n",
    "            print(f\"validation loss: {last_val_loss:.4f}\")\n",
    "            with open(log_file, \"a\") as f:\n",
    "                f.write(f\"{step} val {last_val_loss:.4f}\\n\")\n",
    "\n",
    "    # checkpoint to Drive\n",
    "    if master_process and step > 0 and (step % CHECKPOINT_EVERY == 0 or last_step):\n",
    "        save_checkpoint(step)\n",
    "\n",
    "    # periodic sample generations -- the portfolio-facing signal of progress\n",
    "    if (step > 0 and step % SAMPLE_EVERY == 0) or last_step:\n",
    "        generate(\"Hello, I'm a language model,\", max_new_tokens=24, num_samples=2)\n",
    "\n",
    "    # one optimizer step = grad_accum_steps micro-batches\n",
    "    model.train()\n",
    "    optimizer.zero_grad(set_to_none=True)\n",
    "    loss_accum = 0.0\n",
    "    for micro_step in range(grad_accum_steps):\n",
    "        x, y = train_loader.next_batch()\n",
    "        x, y = x.to(device), y.to(device)\n",
    "        # T4 CHANGE: float16 autocast -- the T4's actual tensor-core fast path\n",
    "        with torch.autocast(device_type=device, dtype=torch.float16):\n",
    "            logits, loss = model(x, y)\n",
    "        loss = loss / grad_accum_steps  # pre-divide so accumulated grads average instead of sum\n",
    "        loss_accum += loss.detach()\n",
    "        scaler.scale(loss).backward()   # scaled backward -- fp16-safe gradient accumulation\n",
    "\n",
    "    # gradients are currently scaled by the GradScaler -- un-scale them first so\n",
    "    # clipping operates on TRUE gradient magnitudes, not scaled ones\n",
    "    scaler.unscale_(optimizer)\n",
    "    norm = torch.nn.utils.clip_grad_norm_(model.parameters(), 1.0)\n",
    "\n",
    "    lr = get_lr(step)\n",
    "    for param_group in optimizer.param_groups:\n",
    "        param_group['lr'] = lr\n",
    "\n",
    "    scaler.step(optimizer)  # skips the step automatically if grads contain inf/nan (rare fp16 overflow)\n",
    "    scaler.update()         # adapts the loss-scale factor for the next step\n",
    "\n",
    "    if device == 'cuda':\n",
    "        torch.cuda.synchronize()\n",
    "    t1 = time.time()\n",
    "    dt = (t1 - t0) * 1000\n",
    "    tokens_processed = train_loader.B * train_loader.T * grad_accum_steps\n",
    "    tokens_per_sec = tokens_processed / (t1 - t0)\n",
    "    print(f\"step {step:4d} | loss: {loss_accum.item():.6f} | norm: {norm:.4f} | lr: {lr:.4e} | dt: {dt:.2f}ms | tok/sec: {tokens_per_sec:.2f}\")\n",
    "    if master_process:\n",
    "        with open(log_file, \"a\") as f:\n",
    "            f.write(f\"{step} train {loss_accum.item():.6f}\\n\")\n",
    "\n",
    "# -----------------------------------------------------------------------------\n",
    "# final export: small weights-only file (~500MB, no optimizer state) -- this is\n",
    "# the artifact you load for the portfolio demo / prompting the model\n",
    "# -----------------------------------------------------------------------------\n",
    "final_export = {\n",
    "    'model': raw_model.state_dict(),\n",
    "    'config': raw_model.config,\n",
    "    'step': step,\n",
    "    'val_loss': last_val_loss,\n",
    "}\n",
    "final_path = os.path.join(drive_checkpoint_dir, \"gpt2_124M_step3000.pt\")  # EXTENSION: separate file, original final export untouched\n",
    "torch.save(final_export, final_path)\n",
    "print(f\"final model saved to {final_path}\")\n",
    "\n",
    "print(\"\\n=== final samples ===\")\n",
    "generate(\"Hello, I'm a language model,\", max_new_tokens=48, num_samples=3)\n",
    "generate(\"The city of Paris is\", max_new_tokens=48, num_samples=3)"
   ]
  }
